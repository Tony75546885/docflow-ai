# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug                          # fatal | error | warn | info | debug | trace

# ── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://docflow:docflow_dev@localhost:5433/docflow?schema=public

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object Storage (S3-compatible / MinIO) ──────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=docflow-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true                 # required for MinIO

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
JWT_EXPIRES_IN=24h
API_KEY_HASH_ROUNDS=12                   # bcrypt rounds for API key hashing

# ── Claude AI ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...             # your Claude API key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_TIMEOUT_MS=120000              # 2 minutes

# ── Webhooks ────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=whsec-change-me   # HMAC-SHA256 signing secret

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_MAX=100                       # requests per window
RATE_LIMIT_WINDOW_MS=60000               # window duration (1 minute)
